    "@typescript-eslint/parser": "^8.58.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0"
  }
